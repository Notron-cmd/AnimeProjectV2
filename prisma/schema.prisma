datasource db {
  provider  = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

// 1. Tabel User untuk Login & Register
model User {
  id        String     @id @default(uuid())
  username  String     @unique
  email     String     @unique
  password  String?
  googleId  String?    @unique
  avatarUrl String?
  createdAt DateTime   @default(now())
  
  // Relasi ke fitur tracker
  bookmarks     Bookmark[]
  favorites     Favorite[]
  genreStats    GenreStat[]
  activityLogs  ActivityLog[]
  notifications Notification[]
  ratings       UserRating[]
}

// 2. Tabel Anime yang berhasil disimpan dari Jikan API
model Anime {
  id          String     @id @default(uuid())
  anilistId   Int        @unique // ID asli dari AniList (tipe data Int)
  title       String
  imageUrl    String
  genres      String[]
  totalEpisodes Int?
  
  bookmarks     Bookmark[]
  favorites     Favorite[]
  activityLogs  ActivityLog[]
  notifications Notification[]
  ratings       UserRating[]
}
// 3. Tabel Bookmark (Simpan untuk Nanti)
model Bookmark {
  id        String    @id @default(uuid())
  userId    String
  animeId   String
  status    String    @default("Plan to Watch") // Watching, Completed, Plan to Watch
  currentEpisode Int  @default(0)
  completedAt DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime     Anime     @relation(fields: [animeId], references: [id], onDelete: Cascade)

  @@unique([userId, animeId]) // User yang sama tidak bisa nge-bookmark anime yang sama dua kali
}

// 4. Tabel Favorite (Anime Kesukaan)
model Favorite {
  id        String   @id @default(uuid())
  userId    String
  animeId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime     Anime    @relation(fields: [animeId], references: [id], onDelete: Cascade)

  @@unique([userId, animeId]) // User yang sama tidak bisa mem-favorite anime yang sama dua kali
}

// 5. GenreStat — track genre distribution per user from bookmarks
model GenreStat {
  id        String   @id @default(uuid())
  userId    String
  genre     String
  count     Int      @default(1)

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, genre])
}

// 6. ActivityLog — track recent user activity
model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  action    String   // 'bookmark', 'favorite', 'remove_bookmark'
  animeId   String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime     Anime?   @relation(fields: [animeId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
}

// 7. UserRating — personal user ratings for anime
model UserRating {
  id        String   @id @default(uuid())
  userId    String
  animeId   String
  score     Int      // 1-10
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime     Anime    @relation(fields: [animeId], references: [id], onDelete: Cascade)

  @@unique([userId, animeId])
}

// 8. Notification — system notifications for users
model Notification {
  id        String   @id @default(uuid())
  userId    String
  animeId   String?
  type      String   // NEW_EPISODE, NOW_AIRING, COMPLETED
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  anime     Anime?   @relation(fields: [animeId], references: [id], onDelete: SetNull)

  @@index([userId, read])
  @@index([userId, createdAt])
}